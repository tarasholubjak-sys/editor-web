# Selfy Knowledge Editor — env variables
# Скопіюй у .env.local для локальної розробки.
# Для Vercel — додай через Project Settings → Environment Variables.

# === LLM API keys ===
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Порядок fallback (gemini → anthropic → openai). Розділяй комами.
LLM_CHAIN=gemini,anthropic,openai

# Опційно — модель OpenAI
OPENAI_MODEL=gpt-5.4-nano

# === Outline API ===
# Базовий API URL (HTTPS, локально через VPN не вийде з Vercel —
# використовуй ПУБЛІЧНИЙ HTTPS endpoint wiki.selfy.com.ua/api)
OUTLINE_BASE_URL=https://wiki.selfy.com.ua/api
OUTLINE_PUBLIC_URL=https://wiki.selfy.com.ua
OUTLINE_API_KEY=
