# Selfy Knowledge Editor — env variables
# Скопіюй у .env.local для локальної розробки.
# На сервері (Ubuntu) — додати в /opt/editor-web/.env

# === LLM API keys ===
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Порядок fallback. Розділяй комами.
# УВАГА: Gemini кредити вичерпані — тримай Anthropic ПЕРШИМ.
LLM_CHAIN=anthropic,openai,gemini

# Опційно — модель OpenAI (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Опційно — модель Anthropic (default: claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# === Outline API ===
OUTLINE_BASE_URL=https://wiki.selfy.com.ua/api
OUTLINE_PUBLIC_URL=https://wiki.selfy.com.ua
OUTLINE_API_KEY=

# === Google Drive (service account) ===
GDRIVE_KEY_PATH=/opt/wiki-selfy-bot/secrets/gdrive-key.json

# === Auth (NextAuth + Google OAuth) ===
# Рандомний секрет: openssl rand -hex 32
AUTH_SECRET=
# Client ID + Secret з Google Cloud Console
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Allowlist email'ів які можуть зайти (через кому, без пробілів)
ALLOWED_EMAILS=tarasholubjak@gmail.com
# За nginx-проксі → trust host headers
AUTH_TRUST_HOST=true
# Публічний URL застосунку (потрібен для OAuth callback після TLS)
AUTH_URL=https://editor.selfy.com.ua
